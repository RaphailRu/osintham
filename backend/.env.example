# OsintHAM — Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=sqlite:///./osintham.db

# Server
HOST=0.0.0.0
PORT=8000

# OSINT API Keys (optional — for live scanning)
SHODAN_API_KEY=
HIBP_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
INTELX_API_KEY=

# Security
SECRET_KEY=change-this-to-a-random-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
